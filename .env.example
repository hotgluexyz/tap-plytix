# Plytix Configuration
# Copy this file to .env and fill in your actual values.
# Variable names follow the tap's setting keys; run `tap-plytix --about` for the
# authoritative list.

# Required: Access key used to authenticate against Plytix
TAP_PLYTIX_ACCESS_KEY=your_access_key_here

# Optional: The earliest record date to sync (ISO-8601)
TAP_PLYTIX_START_DATE=2023-01-01T00:00:00Z

# Optional: API base URL (defaults to https://pim.plytix.com/api/v1)
TAP_PLYTIX_API_URL=https://pim.plytix.com/api/v1
